{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "include-v-in-tag": true,
  "include-component-in-tag": false,
  "packages": {
    ".": {
      "release-type": "simple",
      "extra-files": [
        {
          "path": "package.json",
          "type": "json",
          "jsonpath": "$.version"
        },
        {
          "path": "Cargo.toml",
          "type": "toml",
          "jsonpath": "$.package.version"
        },
        {
          "path": "Cargo.lock",
          "type": "toml",
          "jsonpath": "$.package[?(@.name.value=='idl-language-server')].version"
        }
      ]
    }
  }
}
